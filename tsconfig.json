{
  "compilerOptions": {
    // Базовые настройки
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    // Настройки путей (алиасы)
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["src/app/*"],
      "@pages/*": ["src/pages/*"],
      "@widgets/*": ["./src/widgets/*"],
      "@features/*": ["./src/features/*"],
      "@entities/*": ["./src/entities/*"],
      "@shared/*": ["./src/shared/*"]
    },

    // Важные настройки для React
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // Строгие проверки TypeScript (рекомендуется)
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,

    // Дополнительные полезные настройки
    "allowJs": true,
    "checkJs": false,
    "types": ["vite/client", "node"] // если используете Vite
  },
  // Какие файлы включать в компиляцию
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "vite.config.ts" // если используете Vite
  ],

  // Какие файлы исключить
  "exclude": ["node_modules", "dist", "build", "coverage"]
}
